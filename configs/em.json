    { "keys": ["1"],                    "label": "1",            "description": "Pin spec 1" },
    { "keys": ["2"],                    "label": "2",            "description": "Pin spec 2" },
    { "keys": ["3"],                    "label": "3",            "description": "Pin spec 3" },
    { "keys": ["4"],                    "label": "4",            "description": "Pin spec 4" },
    { "keys": ["5"],                    "label": "5",            "description": "Pin spec 5" },
    { "keys": ["6"],                    "label": "6",            "description": "Pin spec 6" },
    { "keys": ["7"],                    "label": "7",            "description": "Pin spec 7" },
    { "keys": ["8"],                    "label": "8",            "description": "Pin spec 8" },
    { "keys": ["9"],                    "label": "9",            "description": "Pin spec 9" }
  ]
